# Database
DATABASE_URL="postgresql://aphrodite:aphrodite@localhost:5433/aphrodite?schema=public"

# Auth.js
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3002"

# AI provider
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
# Optional USD rates per million tokens; enables estimatedCostMicros telemetry.
OPENAI_INPUT_COST_PER_MILLION=""
OPENAI_OUTPUT_COST_PER_MILLION=""

# Daily server-side message limits (UTC)
CHAT_DAILY_LIMIT_FREE="50"
CHAT_DAILY_LIMIT_PREMIUM="500"
CHAT_DAILY_LIMIT_CREATOR="1000"

# Stripe (required only when billing is enabled)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Recurring $19/month Price configured in Stripe.
STRIPE_PREMIUM_PRICE_ID=""
