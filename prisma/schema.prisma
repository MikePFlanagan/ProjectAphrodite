generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum CharacterCategory {
  ROMANTIC
  FRIENDLY
  MENTOR
  ADVENTURE
  FANTASY
  SCI_FI
  LIFESTYLE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  CREATOR
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              UserRole           @default(USER)
  accounts          Account[]
  sessions          Session[]
  createdCharacters Character[]        @relation("CharacterCreator")
  conversations     Conversation[]
  favorites         Favorite[]
  memories          Memory[]
  subscription      Subscription?
  creatorAssets     CreatorAsset[]
  creatorReferences CreatorReference[]
  chatUsage         ChatUsage[]
  relationships     Relationship[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model CreatorAsset {
  id           String     @id @default(cuid())
  userId       String
  characterId  String?
  assetType    String
  prompt       String     @db.Text
  promptValues Json
  locks        Json
  variation    Int
  palette      Json
  imageUrl     String?    @db.Text
  provider     String     @default("mock")
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  character    Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([userId, characterId, createdAt])
}

model CreatorReference {
  id          String   @id @default(cuid())
  userId      String
  characterId String
  slot        String
  fileName    String
  mimeType    String
  sizeBytes   Int
  dataUrl     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, slot])
  @@index([userId, characterId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Character {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  tagline           String
  description       String             @db.Text
  avatarUrl         String
  coverUrl          String?
  personalityPrompt String             @db.Text
  traits            String[]           @default([])
  personality       Json               @default("{}")
  voiceProvider     String             @default("browser")
  voiceId           String             @default("")
  voiceRate         Float              @default(1)
  voicePitch        Float              @default(1)
  greeting          String             @db.Text
  category          CharacterCategory
  isFeatured        Boolean            @default(false)
  isPublished       Boolean            @default(false)
  creatorId         String?
  creator           User?              @relation("CharacterCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  conversations     Conversation[]
  favorites         Favorite[]
  memories          Memory[]
  creatorAssets     CreatorAsset[]
  creatorReferences CreatorReference[]
  relationships     Relationship[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([isPublished, isFeatured])
  @@index([category])
}

model Conversation {
  id               String      @id @default(cuid())
  userId           String
  characterId      String
  title            String?
  summary          String?     @db.Text
  summaryUpdatedAt DateTime?
  lastMessageAt    DateTime    @default(now())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  character        Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  messages         Message[]
  usage            ChatUsage[]

  @@index([userId, lastMessageAt])
  @@index([characterId])
}

model Relationship {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  trust       Int       @default(50)
  comfort     Int       @default(50)
  curiosity   Int       @default(50)
  playfulness Int       @default(50)
  affection   Int       @default(50)
  respect     Int       @default(50)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([characterId])
}

model ChatUsage {
  id                  String       @id @default(cuid())
  userId              String
  conversationId      String
  model               String
  inputTokens         Int
  outputTokens        Int
  totalTokens         Int
  estimatedCostMicros Int?
  createdAt           DateTime     @default(now())
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Favorite {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model Memory {
  id            String    @id @default(cuid())
  userId        String
  characterId   String
  key           String
  value         String    @db.Text
  importance    Int       @default(1)
  isUserManaged Boolean   @default(false)
  isForgotten   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId, key])
  @@index([userId, characterId, importance, updatedAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}
